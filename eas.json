{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development-biz": {
      "developmentClient": true,
      "distribution": "internal",
      "env": { "APP_FLAVOR": "biz" }
    },
    "development-consumer": {
      "developmentClient": true,
      "distribution": "internal",
      "env": { "APP_FLAVOR": "consumer" }
    },
    "preview-biz": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": { "APP_FLAVOR": "biz" }
    },
    "preview-consumer": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": { "APP_FLAVOR": "consumer" }
    },
    "production-biz": {
      "channel": "production",
      "ios": {
        "distribution": "store",
        "autoIncrement": "buildNumber"
      },
      "android": {
        "buildType": "app-bundle",
        "autoIncrement": "versionCode"
      },
      "env": { "APP_FLAVOR": "biz" }
    },
    "production-consumer": {
      "channel": "production",
      "ios": {
        "distribution": "store",
        "autoIncrement": "buildNumber"
      },
      "android": {
        "buildType": "app-bundle",
        "autoIncrement": "versionCode"
      },
      "env": { "APP_FLAVOR": "consumer" }
    }
  },
  "submit": {
    "production-biz": {
      "ios": {
        "appleId": "APPLE_ID_PLACEHOLDER",
        "ascAppId": "ASC_APP_ID_BIZ_PLACEHOLDER",
        "appleTeamId": "APPLE_TEAM_ID_PLACEHOLDER"
      },
      "android": {
        "serviceAccountKeyPath": "./credentials/play-store-service-account.json",
        "track": "production",
        "releaseStatus": "completed"
      }
    },
    "production-consumer": {
      "ios": {
        "appleId": "APPLE_ID_PLACEHOLDER",
        "ascAppId": "ASC_APP_ID_CONSUMER_PLACEHOLDER",
        "appleTeamId": "APPLE_TEAM_ID_PLACEHOLDER"
      },
      "android": {
        "serviceAccountKeyPath": "./credentials/play-store-service-account.json",
        "track": "production",
        "releaseStatus": "completed"
      }
    }
  }
}
